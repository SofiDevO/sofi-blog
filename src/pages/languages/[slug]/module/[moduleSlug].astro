---
import { getLanguageDetail } from "@services/querys/languages/getLanguageDetail";
import { getModuleDetail } from "@services/querys/modules/getModuleDetail";
import BackArrow from "@shared/icons/BackArrow.astro";
import type { Node3 } from "@src/types/LanguageDetail.type";
import type { ModuleNode } from "@src/types/moduleDetail.type";
import { groupLessonsByModule } from "@utils/groupModules";
import Layout from "../../layouts/Layout.astro";
import MainVideo from "./_components/MainVideo.astro";
import SidebarComplementary from "./_components/SidebarComplementary.astro";
export const prerender = true;

export async function getStaticPaths() {
  const [languages, modules] = await Promise.all([
    getLanguageDetail(),
    getModuleDetail(),
  ]);
  const modulesBySlug = new Map(modules.map((m: ModuleNode) => [m.slug, m]));

  const paths: {
    params: { slug: string; moduleSlug: string };
    props: {
      module: ModuleNode;
      languageSlug: string;
      languageLessons: Node3[];
    };
  }[] = [];

  for (const language of languages ?? []) {
    const lessons = language.curso?.modulo?.nodes ?? [];
    for (const mod of lessons) {
      const moduleDetail = modulesBySlug.get(mod.slug);
      if (!moduleDetail) continue;
      paths.push({
        params: { slug: language.slug, moduleSlug: mod.slug },
        props: {
          module: moduleDetail,
          languageSlug: language.slug,
          languageLessons: lessons,
        },
      });
    }
  }

  return paths;
}

const { module, languageSlug, languageLessons } = Astro.props as {
  module: ModuleNode;
  languageSlug: string;
  languageLessons: Node3[];
};
const { title, content, moduleFields } = module;
const recursos = moduleFields?.recursos?.node?.mediaItemUrl;
const multimedia = moduleFields?.multimedia;

const modulesGrouped = groupLessonsByModule(languageLessons);
---

<Layout title={title} showHeader={false}>
  <section class="module" id="post">
    <header class="module__header">
      <a href={`/languages/${languageSlug}`} class="header__back-btn">
        <BackArrow width={30} height={30} />
      </a>
    </header>

    <div class="module__container">
      <MainVideo
        title={title}
        leccion={moduleFields?.leccion}
        multimedia={multimedia}
      />
      <SidebarComplementary
        content={content}
        recursos={recursos}
        languageSlug={languageSlug}
        module={module}
        modulesGrouped={modulesGrouped}
      />
    </div>
  </section>
</Layout>

<script>
  import { InsertButtonCopy } from "@pages/post/button-copy";
  import "@utils/fast-youtube";
  InsertButtonCopy();
  document.addEventListener("DOMContentLoaded", () => {
    const toggleCompBtn = document.getElementById("toggleComplementarySidebar");
    const compSidebar = document.querySelector(".module__complementary");
    const compIcon = toggleCompBtn?.querySelector("iconify-icon");

    const isCompCollapsed =
      localStorage.getItem("complementarySidebarCollapsed") === "true";
    if (!isCompCollapsed) {
      compSidebar?.classList.add("active");
      if (compIcon) compIcon.setAttribute("icon", "mdi:menu-open");
    } else {
      if (compIcon) compIcon.setAttribute("icon", "mdi:menu");
    }

    toggleCompBtn?.addEventListener("click", () => {
      compSidebar?.classList.toggle("active");
      const nowCompCollapsed = !compSidebar?.classList.contains("active");

      if (compIcon) {
        compIcon.setAttribute(
          "icon",
          nowCompCollapsed ? "mdi:menu" : "mdi:menu-open",
        );
      }

      localStorage.setItem(
        "complementarySidebarCollapsed",
        nowCompCollapsed ? "true" : "false",
      );
    });

    // Tab switching logic
    const tabBtns = document.querySelectorAll(".module__tab-btn");
    const tabPanels = document.querySelectorAll(".module__tab-panel");

    tabBtns.forEach((btn) => {
      btn.addEventListener("click", () => {
        const tabTarget = btn.getAttribute("data-tab");
        if (!tabTarget) return;

        // Update active tab button
        tabBtns.forEach((b) => b.classList.remove("active"));
        btn.classList.add("active");

        // Update active panel
        tabPanels.forEach((panel) => {
          if (panel.getAttribute("data-panel") === tabTarget) {
            panel.classList.add("active");
          } else {
            panel.classList.remove("active");
          }
        });
      });
    });

    const container = document.getElementById("post") as HTMLElement;
    const allImages = container.querySelectorAll<HTMLImageElement>("img");
    const dialog = container.querySelector("dialog") as HTMLDialogElement;
    const body = document.querySelector("body") as HTMLBodyElement;

    allImages.forEach((image) => {
      image.addEventListener("click", () => {
        if (!dialog) return;
        dialog.open = true;
        body.classList.add("overflow-hidden");
        const imageSrc = image.getAttribute("src");
        const imageAlt = image.getAttribute("alt") || "Image";
        const imageRender = document.createElement("img");
        imageRender.src = imageSrc || "";
        imageRender.alt = imageAlt;
        dialog.appendChild(imageRender);
      });
    });

    dialog?.addEventListener("click", () => {
      dialog.close();
      body.classList.remove("overflow-hidden");
      dialog.innerHTML = "";
    });
  });
</script>

<style lang="scss">
  @use "sass:color";
  @use "@sass/variables" as *;
  @use "@sass/mixins" as *;

  .module {
    width: 100%;
    // max-width: 1100px;
    margin: 0 auto !important;
    padding: 1rem 0.5rem;

    &__header {
      margin-bottom: 2rem;
      & a {
        display: flex;
        align-items: center;
        background-color: $bgDark;
        padding: 0.8rem 1rem;
        border-radius: 0.2rem;
        color: #33ff76;
        width: fit-content;
        border-radius: 10px;
      }
    }

    &__title {
      font-size: 3rem;
      font-weight: 700;
    }

    &__container {
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 0.5rem;
      align-items: flex-start;
      padding: 0 1rem;

      @include respond-to("medium") {
        grid-template-columns: 1fr;
      }
    }

    &__icon {
      position: sticky;
      top: 4rem;
      width: 100%;
      max-width: 300px;
      height: auto;

      @include respond-to("medium") {
        position: static;
        width: 80%;
        max-width: none;
      }

      &:hover {
        filter: drop-shadow(0 0 0.75rem $ufo-green);
        transition: filter 1s ease-in-out;
      }
    }
  }
</style>
