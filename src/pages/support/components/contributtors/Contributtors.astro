---
import { getContributtors } from "@services/querys/contributors/getContributors.js";
import type { CardContributtor } from "@src/types/contributtors.types.ts";
import "./_contributtors.scss";
import "./contributor-card/_contributor-card.scss";
import ContributorCard from "./contributor-card/ContributorCard.astro";

const contributors: CardContributtor[] = await getContributtors();
---

<section class="contributtors">
  {
    contributors.length > 0 ? (
      <ul class="contributtors__list">
        {contributors.map((contributor: CardContributtor) => (
          <ContributorCard contributor={contributor} />
        ))}
      </ul>
    ) : (
      <p class="contributtors__empty">
        Los contribuidores se fueron de sabático, Cariño.
      </p>
    )
  }
</section>
