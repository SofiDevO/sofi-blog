---
import Layout from "@layouts/Layout.astro";
import { getLanguageDetail } from "@services/querys/languages/getLanguageDetail";
import { getModuleDetail } from "@services/querys/modules/getModuleDetail";
import BackArrow from "@shared/icons/BackArrow.astro";
import type { ModuleNode } from "@src/types/moduleDetail.type";
import type { Node3 } from "@src/types/LanguageDetail.type";
import { groupLessonsByModule } from "@utils/groupModules";
export const prerender = true;

export async function getStaticPaths() {
  const [languages, modules] = await Promise.all([
    getLanguageDetail(),
    getModuleDetail(),
  ]);
  const modulesBySlug = new Map(modules.map((m: ModuleNode) => [m.slug, m]));

  const paths: {
    params: { slug: string; moduleSlug: string };
    props: { module: ModuleNode; languageSlug: string; languageLessons: Node3[] };
  }[] = [];

  for (const language of languages ?? []) {
    const lessons = language.curso?.modulo?.nodes ?? [];
    for (const mod of lessons) {
      const moduleDetail = modulesBySlug.get(mod.slug);
      if (!moduleDetail) continue;
      paths.push({
        params: { slug: language.slug, moduleSlug: mod.slug },
        props: { 
          module: moduleDetail, 
          languageSlug: language.slug,
          languageLessons: lessons
        },
      });
    }
  }

  return paths;
}

const { module, languageSlug, languageLessons } = Astro.props as {
  module: ModuleNode;
  languageSlug: string;
  languageLessons: Node3[];
};
const { title, content, featuredImage, moduleFields } = module;
const recursos = moduleFields?.recursos?.node?.mediaItemUrl;
const multimedia = moduleFields?.multimedia;

const modulesGrouped = groupLessonsByModule(languageLessons);
---

<Layout title={title}>
  <section class="module" id="module">
    <header class="module__header">
      <a href={`/languages/${languageSlug}`} class="header__back-btn">
        <BackArrow width={30} height={30} />
      </a>
    </header>

    <div class="module__container">
      {
        featuredImage && (
          <img
            class="module__icon"
            src={featuredImage.node.mediaItemUrl}
            srcset={featuredImage.node.srcSet}
            sizes={featuredImage.node.sizes}
            alt={featuredImage.node.altText}
          />
        )
      }

      <div class="module__content">
        {
          moduleFields?.modulo && (
            <span class="module__category">{moduleFields.modulo}</span>
          )
        }
        <h1 class="text-gradient module__title">
          {moduleFields?.leccion ? `${moduleFields.leccion}: ` : ""}
          {title}
        </h1>

        <div set:html={multimedia} />
        <div set:html={content} />

        {
          recursos && (
            <a
              class="module__resource-btn"
              href={recursos}
              target="_blank"
              rel="noopener noreferrer"
            >
              📎 Descargar recursos
            </a>
          )
        }
      </div>

      <aside class="module__sidebar">
        {
          modulesGrouped && Object.keys(modulesGrouped).length > 0 && (
            <div class="language__accordion-container">
              {Object.entries(modulesGrouped).map(([moduleName, lessons]) => (
                <details class="language__accordion" open>
                  <summary class="language__summary">
                    <span>{moduleName}</span>
                  </summary>
                  <ul class="language__lessons">
                    {lessons.map((lesson) => (
                      <li class="language__lesson">
                        <a
                          data-astro-prefetch="hover"
                          href={`/languages/${languageSlug}/module/${lesson.slug}`}
                        >
                          {lesson.moduleFields?.leccion && (
                            <span class="lesson__number">{lesson.moduleFields.leccion}: </span>
                          )}
                          <span class="lesson__title">{lesson.title}</span>
                        </a>
                      </li>
                    ))}
                  </ul>
                </details>
              ))}
            </div>
          )
        }
      </aside>
    </div>
  </section>
</Layout>

<script>
  import { InsertButtonCopy } from "@pages/post/button-copy";
  InsertButtonCopy();
</script>
<script>
  document.addEventListener("DOMContentLoaded", () => {
    const container = document.getElementById("module") as HTMLElement;
    const allImages = container.querySelectorAll<HTMLImageElement>("img");
    const dialog = container.querySelector("dialog") as HTMLDialogElement;
    const body = document.querySelector("body") as HTMLBodyElement;

    allImages.forEach((image) => {
      image.addEventListener("click", () => {
        if (!dialog) return;
        dialog.open = true;
        body.classList.add("overflow-hidden");
        const imageSrc = image.getAttribute("src");
        const imageAlt = image.getAttribute("alt") || "Image";
        const imageRender = document.createElement("img");
        imageRender.src = imageSrc || "";
        imageRender.alt = imageAlt;
        dialog.appendChild(imageRender);
      });
    });

    dialog?.addEventListener("click", () => {
      dialog.close();
      body.classList.remove("overflow-hidden");
      dialog.innerHTML = "";
    });
  });
</script>

<style lang="scss">
  @use "sass:color";
  @use "@sass/variables" as *;
  @use "@sass/mixins" as *;

  .module {
    width: 100%;
    max-width: 1100px;
    margin: 10rem auto;
    padding: 1rem;

    &__header {
      margin-bottom: 2rem;
    }

    &__title {
      font-size: 5rem;
      margin-bottom: 2rem;
      font-weight: 700;
    }

    &__container {
      display: flex;
      align-items: flex-start;
      gap: 3rem;
      padding: 0 1rem;

      @include respond-to("medium") {
        flex-direction: column;
        align-items: center;
      }
    }

    &__icon {
      position: sticky;
      top: 4rem;
      width: 100%;
      max-width: 300px;
      height: auto;

      @include respond-to("medium") {
        position: static;
        width: 80%;
        max-width: none;
      }

      &:hover {
        filter: drop-shadow(0 0 0.75rem $ufo-green);
        transition: filter 1s ease-in-out;
      }
    }

    &__content {
      flex: 1;
      display: flex;
      flex-direction: column;
      gap: 2rem;
    }

    &__sidebar {
      width: 320px;
      flex-shrink: 0;

      @include respond-to("medium") {
        width: 100%;
      }
    }

    &__category {
      font-size: 1.6rem;
      font-weight: 700;
      color: #a855f7;
      text-transform: uppercase;
      letter-spacing: 0.1rem;
    }

    &__resource-btn {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      background: $french-violet;
      color: #fff;
      padding: 0.75rem 1.5rem;
      border-radius: 8px;
      text-decoration: none;
      font-weight: 600;
      width: fit-content;
      transition: background 0.3s ease-in-out;

      &:hover {
        background: color.adjust($french-violet, $lightness: 10%);
      }
    }
  }
</style>
