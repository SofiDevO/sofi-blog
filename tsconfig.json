{
  "extends": "astro/tsconfigs/base",
  "include": ["src/**/*"],
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "allowJs": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@/layouts/*": ["./src/layouts/*"],
      "@/components/*": ["./src/components/*"]
    }
  }
}
