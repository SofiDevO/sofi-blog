---
import Title from "@src/components/atoms/Title/Title.astro";

import SwiperCarousel from "@src/shared/components/SwiperCarousel/SwiperCarousel.astro";
import type { CategoryWithPosts } from "@src/types/category.type";
import PostCard from "../components/PostCard/PostCard.astro";

type Variant = "default" | "horizontal" | "compact";
interface Props extends CategoryWithPosts {
  variant?: Variant;
}
const { slug, name, posts, variant } = Astro.props;
---

<section class="fourth-category">
  <a href={`/categories/${slug}`} class="web-dev__link">
    <Title titleDesc={name} class="web-dev__title text-left" />
  </a>
  <div class="swiper">
    <SwiperCarousel
      class="fourth-category-swiper"
      config={{
        slidesPerView: 3,
        spaceBetween: 1,
        autoplay: {
          delay: 2500,
          disableOnInteraction: true,
        },
        breakpoints: {
          640: { slidesPerView: 1, spaceBetween: 20 },
          768: { slidesPerView: 3, spaceBetween: 40 },
          1024: { slidesPerView: 3, spaceBetween: 50 },
        },
        navigation: true,
        pagination: true,
        loop: true,
      }}
    >
      {
        posts.map((post) => {
          return (
            <swiper-slide>
              <PostCard variant={variant} {...post} class="slider__card" />
            </swiper-slide>
          );
        })
      }
    </SwiperCarousel>
  </div>
</section>
