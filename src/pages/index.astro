---
import DividerTop from "@atoms/DividerTop/DividerTop.astro";
import Layout from "@layouts/Layout.astro";
import Hero from "@organisms/Hero/Hero.astro";
import FirstCategory from "@organisms/Posts/FirstCategory/FirstCategory.astro";
import SecondCategory from "@organisms/Posts/SecondCategory/SecondCategory.astro";
import { getCategoriesWithPosts } from "@services/categoriesWithPosts";
import BackgroundGradient from "@src/components/atoms/BackgroundGradient/BackgroundGradient.astro";
import DividerBottom from "@src/components/atoms/DividerBottom/DividerBottom.astro";
import Infinitecarousel from "@src/components/organisms/infinite-carousel/Infinitecarousel.astro";
import FourthCategory from "@src/components/organisms/Posts/FourthCategory/FourthCategory.astro";
import ThirdCategory from "@src/components/organisms/Posts/ThirdCategory/ThirdCategory.astro";
const categoriesWithPosts = await getCategoriesWithPosts();
// export const prerender = true;
---

<Layout>
  <BackgroundGradient>
    <Hero title="Bienvenidos al SofiBlog" />
  </BackgroundGradient>
  <DividerTop fill="shape-fill-darkPurple" />
  {
    categoriesWithPosts["noticias-dev"] && (
      <FourthCategory
        {...categoriesWithPosts["noticias-dev"][0]}
        variant="horizontal"
      />
    )
  }
  <Infinitecarousel />
  <div class="add__block">
    <script
      is:inline
      async
      src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-3828278469742835"
      crossorigin="anonymous"></script>
    <!-- banerHorzontal -->
    <ins
      class="adsbygoogle"
      style="display:block"
      data-ad-client="ca-pub-3828278469742835"
      data-ad-slot="1391467357"
      data-ad-format="auto"
      data-full-width-responsive="true"></ins>
    <script is:inline>
      (adsbygoogle = window.adsbygoogle || []).push({});
    </script>
  </div>
  {
    categoriesWithPosts["tutoriales"] && (
      <FirstCategory {...categoriesWithPosts["tutoriales"][0]} />
    )
  }
  <DividerTop fill="shape-fill-white" />
  {
    categoriesWithPosts["aprender-a-programar"] && (
      <SecondCategory {...categoriesWithPosts["aprender-a-programar"][0]} />
    )
  }
  <DividerBottom fill="shape-fill-white" />
  <div class="add__block">
    <script
      is:inline
      async
      src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-3828278469742835"
      crossorigin="anonymous"></script>
    <!-- banerHorzontal -->
    <ins
      class="adsbygoogle"
      style="display:block"
      data-ad-client="ca-pub-3828278469742835"
      data-ad-slot="1391467357"
      data-ad-format="auto"
      data-full-width-responsive="true"></ins>
    <script is:inline>
      (adsbygoogle = window.adsbygoogle || []).push({});
    </script>
  </div>
  {
    categoriesWithPosts["astro"] && (
      <ThirdCategory {...categoriesWithPosts["astro"][0]} />
    )
  }
  <div class="add__block">
    <script
      is:inline
      async
      src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-3828278469742835"
      crossorigin="anonymous"></script>
    <!-- banerHorzontal -->
    <ins
      class="adsbygoogle"
      style="display:block"
      data-ad-client="ca-pub-3828278469742835"
      data-ad-slot="1391467357"
      data-ad-format="auto"
      data-full-width-responsive="true"></ins>
    <script is:inline>
      (adsbygoogle = window.adsbygoogle || []).push({});
    </script>
  </div>
  <DividerTop fill="shape-fill-white" />
  {
    categoriesWithPosts["javascript"] && (
      <SecondCategory
        reverse={true}
        {...categoriesWithPosts["javascript"][0]}
      />
    )
  }
  <DividerBottom fill="shape-fill-white" />
  {
    categoriesWithPosts["personal"] && (
      <FourthCategory {...categoriesWithPosts["personal"][0]} />
    )
  }
</Layout>

<style lang="scss">
  .add__block {
    display: flex;
    align-items: center;
    justify-content: center;
    // background: black;
    width: 100%;
    max-width: 900px;
    height: auto;
    display: flex;
    justify-content: center;
    margin: 4rem auto;
  }
</style>
