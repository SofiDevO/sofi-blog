---
import Layout from "@layouts/Layout.astro";
import { isLoggedIn } from "@services/auth";
import PasswordInput from "@shared/components/PasswordInput/PasswordInput.astro";

const { cookies } = Astro;
const user = isLoggedIn(cookies);

if (user) {
  return Astro.redirect("/dashboard");
} else if (cookies.has("accessToken")) {
  cookies.delete("accessToken", { path: "/" });
}

const error = Astro.url.searchParams.get("error");
const message = Astro.url.searchParams.get("message");
const success = Astro.url.searchParams.get("success");
---

<Layout title="Login">
  <div class="container__login">
    <form action="/api/auth/login" method="POST" id="loginForm">
      {
        success === "registered" && (
          <div class="success-message">
            Registro exitoso. Ahora puedes iniciar sesión.
          </div>
        )
      }
      {
        error && (
          <div class="error-message">
            {message === "invalid_credentials"
              ? "Usuario o contraseña incorrectos"
              : "Por favor, completa todos los campos"}
          </div>
        )
      }
      <label for="username">Username:</label>
      <input
        type="text"
        id="username"
        name="username"
        autocomplete="username"
        required
      />
      <PasswordInput autocomplete="current-password" />
      <button type="submit"> Login </button>
      <div class="form__cta">
        <span>
          ¿No tienes una cuenta? <a href="/register">Registrate</a>
        </span>
      </div>
    </form>
  </div>
</Layout>

<style lang="scss">
  @use "@sass/variables.scss" as *;
  .container__login {
    display: flex;
    justify-content: center;
    align-items: center;
    height: 100vh;
    font-size: 1.5rem;
  }

  form {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    color: white;
    background: #1f2335;
    padding: 2rem;
    border-radius: 10px;
  }

  button {
    padding: 0.5rem;
    background: #673ab7;
    border: none;
    border-radius: 5px;
    cursor: pointer;
  }
  input {
    border-radius: 10px;
    padding: 0.25rem 0.5rem;
    color: black;
    width: 100%;
  }
  textarea:focus,
  input:focus {
    color: #201b2b79;
  }
  .error-message {
    background-color: #ff5252;
    color: white;
    padding: 0.5rem;
    border-radius: 5px;
    text-align: center;
    font-size: 1rem;
    margin-bottom: 0.5rem;
  }
  .success-message {
    background-color: #4caf50;
    color: white;
    padding: 0.5rem;
    border-radius: 5px;
    text-align: center;
    font-size: 1rem;
    margin-bottom: 0.5rem;
  }
  .form__cta {
    display: flex;
    justify-content: center;
    text-align: center;
    & a {
      color: $ufo-green;
      text-decoration: none;
      font-weight: bold;
      &:hover {
        text-decoration: underline;
      }
    }
  }
</style>
