---
import { isLoggedIn } from "@services/auth";
import { getPostsByUserID } from "@services/querys/posts/getPostBySlug";
import Layout from "./Layout.astro";

export const prerender = false;
const { cookies } = Astro;
const user = isLoggedIn(cookies);
if (!user) {
  return Astro.redirect("/login");
}

// Redirect if user doesn't have required roles
const allowedRoles = ["author", "administrator"];
const hasAccess = user.roles && allowedRoles.some((role) => user.roles.includes(role));

if (!hasAccess) {
  return Astro.redirect("/dashboard");
}

const queryPosts = await getPostsByUserID(user.id);
const posts = queryPosts?.posts?.edges || [];
---

<Layout>
  <section class="posts-section">
    <h1>Mis Posts</h1>

    {
      posts.length > 0 ? (
        <div class="posts-grid">
          {posts.map((post: any) => {
            const image =
              post.node.featuredImage?.node?.mediaItemUrl ||
              "/img/branding/logo.webp";
            const altText =
              post.node.featuredImage?.node?.altText || post.node.title;
            return (
              <article class="post-card">
                <div class="post-card-image">
                  <img src={image} alt={altText} loading="lazy" />
                </div>
                <div class="post-card-content">
                  <h3>{post.node.title}</h3>
                  <a
                    href={`/post/${post.node.slug || post.node.id}`}
                    class="read-more"
                  >
                    Ver post &rarr;
                  </a>
                </div>
              </article>
            );
          })}
        </div>
      ) : (
        <p class="no-posts">Aún no has publicado ningún post.</p>
      )
    }
  </section>
</Layout>



