{
  "extends": "astro/tsconfigs/base",
  "include": ["src/**/*"],
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "allowJs": true,
    "baseUrl": ".",
    "paths": {
      "@src/": ["src/"],
      "@shared/": ["src/shared/"],
      "@layouts/": ["src/layouts/"],
      "@utils/": ["src/utils/"],
      "@content/": ["src/content/"],
      "@pages/": ["src/pages/"],
      "@controllers/": ["src/controllers/"],
      "@services/": ["src/services/"],
      "@sass/": ["src/sass/"],
      "@img/": ["public/img/"]
    }
  }
}
