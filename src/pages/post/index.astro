---
import Layout from "@/layouts/Layout.astro";
import { getCategoriesWithPosts } from "@/services/querys/posts/getCategoriesWithPosts";
import BackgroundGradient from "@/shared/ui/BackgroundGradient.astro";
import DividerBottom from "@/shared/ui/DividerBottom.astro";
import DividerTop from "@/shared/ui/DividerTop.astro";
import FirstCategory from "../home/_components/FirstCategory.astro";
import FourthCategory from "../home/_components/FourthCategory.astro";
import Hero from "../home/_components/Hero.astro";
import SecondCategory from "../home/_components/SecondCategory.astro";
import ThirdCategory from "../home/_components/ThirdCategory.astro";

const categoriesWithPosts = await getCategoriesWithPosts();
export const prerender = true;
---

<Layout>
  <BackgroundGradient>
    <Hero title="Bienvenidos al SofiBlog" />
  </BackgroundGradient>
  <DividerTop fill="shape-fill-darkPurple" />
  {
    categoriesWithPosts["tutoriales"]?.[0] && (
      <FirstCategory {...categoriesWithPosts["tutoriales"][0]} />
    )
  }
  <DividerTop fill="shape-fill-white" />
  <script
    is:inline
    async
    src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-3828278469742835"
    crossorigin="anonymous"></script>
  <!-- banerHorzontal -->
  <ins
    class="adsbygoogle"
    style="display:block"
    data-ad-client="ca-pub-3828278469742835"
    data-ad-slot="1391467357"
    data-ad-format="auto"
    data-full-width-responsive="true"></ins>
  <script is:inline>
    (adsbygoogle = window.adsbygoogle || []).push({});
  </script>
  {
    categoriesWithPosts["aprender-a-programar"]?.[0] && (
      <SecondCategory {...categoriesWithPosts["aprender-a-programar"][0]} />
    )
  }
  <DividerBottom fill="shape-fill-white" />
  <script
    is:inline
    async
    src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-3828278469742835"
    crossorigin="anonymous"></script>
  <!-- banerHorzontal -->
  <ins
    class="adsbygoogle"
    style="display:block"
    data-ad-client="ca-pub-3828278469742835"
    data-ad-slot="1391467357"
    data-ad-format="auto"
    data-full-width-responsive="true"></ins>
  <script is:inline>
    (adsbygoogle = window.adsbygoogle || []).push({});
  </script>
  {
    categoriesWithPosts["astro"]?.[0] && (
      <ThirdCategory {...categoriesWithPosts["astro"][0]} />
    )
  }
  <DividerTop fill="shape-fill-white" />
  <script
    is:inline
    async
    src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-3828278469742835"
    crossorigin="anonymous"></script>
  <!-- banerHorzontal -->
  <ins
    class="adsbygoogle"
    style="display:block"
    data-ad-client="ca-pub-3828278469742835"
    data-ad-slot="1391467357"
    data-ad-format="auto"
    data-full-width-responsive="true"></ins>
  <script is:inline>
    (adsbygoogle = window.adsbygoogle || []).push({});
  </script>
  {
    categoriesWithPosts["javascript"]?.[0] && (
      <SecondCategory
        reverse={true}
        {...categoriesWithPosts["javascript"][0]}
      />
    )
  }
  <DividerBottom fill="shape-fill-white" />
  <script
    is:inline
    async
    src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-3828278469742835"
    crossorigin="anonymous"></script>
  <!-- banerHorzontal -->
  <ins
    class="adsbygoogle"
    style="display:block"
    data-ad-client="ca-pub-3828278469742835"
    data-ad-slot="1391467357"
    data-ad-format="auto"
    data-full-width-responsive="true"></ins>
  <script is:inline>
    (adsbygoogle = window.adsbygoogle || []).push({});
  </script>

  {
    categoriesWithPosts["escritura"]?.[0] && (
      <FourthCategory {...categoriesWithPosts["escritura"][0]} />
    )
  }
  <script
    is:inline
    async
    src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-3828278469742835"
    crossorigin="anonymous"></script>
  <!-- banerHorzontal -->
  <ins
    class="adsbygoogle"
    style="display:block"
    data-ad-client="ca-pub-3828278469742835"
    data-ad-slot="1391467357"
    data-ad-format="auto"
    data-full-width-responsive="true"></ins>
  <script is:inline>
    (adsbygoogle = window.adsbygoogle || []).push({});
  </script>
</Layout>
