---
import Layout from "@layouts/Layout.astro";
import { getLanguageDetail } from "@services/querys/languages/getLanguageDetail";
import BackArrow from "@shared/icons/BackArrow.astro";
import type { Node } from "@src/types/LanguageDetail.type";
import { groupLessonsByModule } from "@utils/groupModules";
export const prerender = true;

export async function getStaticPaths() {
  const data = await getLanguageDetail();
  return data?.map((language: Node) => ({
    params: { slug: language.slug },
    props: { language },
  }));
}

const { language } = Astro.props as { language: Node };
const { title, curso, content } = language;
const { icon, modulo } = curso;

const modulesGrouped = groupLessonsByModule(modulo?.nodes || []);
---

<Layout title={title}>
  <section class="language" id="post">
    <header class="language__header">
      <a href="/languages" class="header__back-btn">
        <BackArrow width={30} height={30} />
      </a>
    </header>
    <div class="language__container">
      <img
        class="language__icon"
        src={icon.node.mediaItemUrl}
        srcset={icon.node.srcSet}
        sizes={icon.node.sizes}
        alt={title}
      />
      <div class="language__content">
        <h1 class="text-gradient language__title">{title}</h1>
        <div set:html={content} />
        {
          modulesGrouped && Object.keys(modulesGrouped).length > 0 && (
            <div class="language__accordion-container">
              {Object.entries(modulesGrouped).map(([moduleName, lessons]) => (
                <details class="language__accordion" open>
                  <summary class="language__summary">
                    <span>{moduleName}</span>
                  </summary>
                  <ul class="language__lessons">
                    {lessons.map((lesson) => (
                      <li class="language__lesson">
                        <a
                          data-astro-prefetch="hover"
                          href={`/languages/${language.slug}/module/${lesson.slug}`}
                        >
                          {lesson.moduleFields?.leccion && (
                            <span class="lesson__number">
                              {lesson.moduleFields.leccion}:{" "}
                            </span>
                          )}
                          <span class="lesson__title">{lesson.title}</span>
                        </a>
                      </li>
                    ))}
                  </ul>
                </details>
              ))}
            </div>
          )
        }
      </div>
    </div>
  </section>
</Layout>

<script>
  import { InsertButtonCopy } from "@pages/post/button-copy";
  InsertButtonCopy();
</script>
<script>
  document.addEventListener("DOMContentLoaded", () => {
    const container = document.getElementById("post") as HTMLElement;
    const allImages = container.querySelectorAll<HTMLImageElement>("img");
    const dialog = container.querySelector("dialog") as HTMLDialogElement;
    const body = document.querySelector("body") as HTMLBodyElement;

    allImages.forEach((image) => {
      image.addEventListener("click", () => {
        dialog.open = true;
        body.classList.add("overflow-hidden");
        const imageSrc = image.getAttribute("src");
        const imageAlt = image.getAttribute("alt") || "Image";
        const imageRender = document.createElement("img");
        imageRender.src = imageSrc || "";
        imageRender.alt = imageAlt;
        dialog.appendChild(imageRender);
      });
    });

    dialog.addEventListener("click", () => {
      dialog.close();
      body.classList.remove("overflow-hidden");
      dialog.innerHTML = "";
    });
  });
</script>

<style lang="scss">
  @use "@sass/variables" as *;
  @use "@sass/mixins" as *;
  .language {
    width: 100%;
    max-width: 1100px;
    margin: 10rem auto;
    padding: 1rem;
    &__title {
      font-size: 5rem;
      margin-bottom: 2rem;
      font-weight: 700;
    }
    &__container {
      @include flexConfig(center, flex-start);
      gap: 2rem;
      padding: 0 1rem;
      @include respond-to("medium") {
        flex-direction: column;
        align-items: center;
      }
    }
    &__icon {
      position: sticky;
      top: 4rem;
      width: 100%;
      max-width: 300px;
      height: auto;
      @include respond-to("medium") {
        position: static;
        width: 80%;
        max-width: none;
      }
      &:hover {
        filter: drop-shadow(0 0 0.75rem $ufo-green);
        transition: filter 1s ease-in-out;
      }
    }
    &__accordion-container {
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
      margin-top: 2rem;
      width: 100%;
    }
    &__accordion {
      width: 100%;
      border-radius: 8px;
      border: 1px solid rgba(0, 255, 255, 0.25);
      background-color: rgba(65, 24, 145, 0.2);
      transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
      overflow: hidden;

      &[open] {
        border-color: rgba(0, 255, 255, 0.5);
        background-color: rgba(65, 24, 145, 0.4);
        box-shadow: 0 4px 20px rgba(0, 255, 255, 0.1);
      }
    }
    &__summary {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 1.25rem 1.5rem;
      color: #33ff76;
      font-size: 2rem;
      font-weight: 700;
      cursor: pointer;
      user-select: none;
      list-style: none;
      transition: background-color 0.2s ease;

      &::-webkit-details-marker {
        display: none;
      }

      &:hover {
        background-color: rgba(255, 255, 255, 0.05);
        color: #00ffff;
      }

      &::after {
        content: "►";
        font-size: 1.2rem;
        color: #00ffff;
        transition: transform 0.3s ease;
      }
    }
    &__accordion[open] &__summary {
      border-bottom: 1px solid rgba(0, 255, 255, 0.15);
      &::after {
        transform: rotate(90deg);
      }
    }
    &__lessons {
      list-style: none;
      padding: 1.25rem 2rem;
      display: flex;
      flex-direction: column;
      gap: 1rem;
      background-color: rgba(0, 0, 0, 0.25);
    }
    &__lesson {
      a {
        display: flex;
        align-items: baseline;
        gap: 0.5rem;
        font-size: 1.8rem;
        font-weight: 600;
        color: rgba(70, 216, 179, 0.9);
        text-decoration: none;
        transition: all 0.2s ease;

        &:hover {
          color: #33ff76;
          transform: translateX(4px);
        }
      }
      .lesson__number {
        color: #a855f7;
        font-weight: 700;
      }
      .lesson__title {
        flex: 1;
      }
    }
  }
</style>
