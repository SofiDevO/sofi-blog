---
import BaseLayout from "@layouts/Layout.astro";

interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const { title, description, image } = Astro.props;
---

<BaseLayout title={title} description={description} image={image}>
  <div class="post-container" id="post">
    <dialog
      class="popup__image w-full open:flex justify-center items-center h-full fixed left-0 top-0 p-5"
    >
    </dialog>
    <slot />
  </div>
</BaseLayout>
<style is:global lang="scss">
  @use "@sass/variables" as *;
  @use "@sass/mixins" as *;
  @use "@sass/post";

  .language {
    width: 100%;
    max-width: 1100px;
    margin: 10rem auto;
    padding: 1rem;
    &__title {
      font-size: 5rem;
      margin-bottom: 2rem;
      font-weight: 700;
    }
    &__container {
      @include flexConfig(center, flex-start);
      gap: 2rem;
      padding: 0 1rem;
      @include respond-to("medium") {
        flex-direction: column;
        align-items: center;
      }
    }
    &__icon {
      position: sticky;
      top: 4rem;
      width: 100%;
      max-width: 300px;
      height: auto;
      @include respond-to("medium") {
        position: static;
        width: 80%;
        max-width: none;
      }
      &:hover {
        filter: drop-shadow(0 0 0.75rem $ufo-green);
        transition: filter 1s ease-in-out;
      }
    }
    &__accordion-container {
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
      margin-top: 2rem;
      width: 100%;
    }
    &__accordion {
      width: 100%;
      border-radius: 8px;
      border: 1px solid rgba(0, 255, 255, 0.25);
      background-color: rgba(65, 24, 145, 0.2);
      transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
      overflow: hidden;

      &[open] {
        border-color: rgba(0, 255, 255, 0.5);
        background-color: rgba(65, 24, 145, 0.4);
        box-shadow: 0 4px 20px rgba(0, 255, 255, 0.1);
      }
    }
    &__summary {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 1.25rem 1.5rem;
      color: #33ff76;
      font-size: 2rem;
      font-weight: 700;
      cursor: pointer;
      user-select: none;
      list-style: none;
      transition: background-color 0.2s ease;

      &::-webkit-details-marker {
        display: none;
      }

      &:hover {
        background-color: rgba(255, 255, 255, 0.05);
        color: #00ffff;
      }

      &::after {
        content: "►";
        font-size: 1.2rem;
        color: #00ffff;
        transition: transform 0.3s ease;
      }
    }
    &__accordion[open] &__summary {
      border-bottom: 1px solid rgba(0, 255, 255, 0.15);
      &::after {
        transform: rotate(90deg);
      }
    }
    &__lessons {
      list-style: none;
      padding: 1.25rem 2rem;
      display: flex;
      flex-direction: column;
      gap: 1rem;
      background-color: rgba(0, 0, 0, 0.25);
    }
    &__lesson {
      a {
        display: flex;
        align-items: baseline;
        gap: 0.5rem;
        font-size: 1.8rem;
        font-weight: 600;
        color: rgba(70, 216, 179, 0.9);
        text-decoration: none;
        transition: all 0.2s ease;

        &:hover {
          color: #33ff76;
          transform: translateX(4px);
        }
      }
      .lesson__number {
        color: #a855f7;
        font-weight: 700;
      }
      .lesson__title {
        flex: 1;
      }
    }
  }
</style>

<script>
  import "@utils/fast-youtube";
  document.addEventListener("DOMContentLoaded", () => {
    const container = document.getElementById("container-post") as HTMLElement;
    const allImages = container.querySelectorAll<HTMLImageElement>("img");
    const dialog = container.querySelector("dialog") as HTMLDialogElement;
    const body = document.querySelector("body") as HTMLBodyElement;

    allImages.forEach((image) => {
      image.addEventListener("click", () => {
        dialog.open = true;
        body.classList.add("overflow-hidden");
        const imageSrc = image.getAttribute("src");
        const imageAlt = image.getAttribute("alt") || "Image";
        const imageRender = document.createElement("img");
        imageRender.src = imageSrc || "";
        imageRender.alt = imageAlt;
        dialog.appendChild(imageRender);
      });
    });

    dialog.addEventListener("click", () => {
      dialog.close();
      body.classList.remove("overflow-hidden");
      dialog.innerHTML = "";
    });
  });
</script>
